                    <span>{totalValue.toFixed(2)} <small className="text-xs font-normal">PLN</small></span>
                  </div>
                </div>

                <button 
                  onClick={() => window.print()}
                  className="w-full bg-orange-600 hover:bg-orange-500 text-white py-5 rounded-2xl font-black text-lg flex items-center justify-center gap-3 transition-all transform active:scale-95 shadow-xl shadow-orange-950/20"
                >
                  <Printer size={22} /> GENERUJ PDF
                </button>
              </>
            )}
          </div>
        </aside>
      </main>

      {/* Print-Only Template (Professional Invoice Style) */}
      <div className="hidden print:block p-16 bg-white min-h-screen text-black">
        <div className="flex justify-between items-end border-b-8 border-amber-900 pb-12 mb-12">
          <div>
            <div className="flex items-center gap-6 mb-4">
              <div className="bg-amber-900 text-white p-4 rounded-3xl">
                <Coffee size={50} />
              </div>
              <h1 className="text-6xl font-black uppercase italic tracking-tighter text-amber-900">Fotoastra</h1>
            </div>
            <p className="text-xl font-bold text-orange-600">Specjalistyczna Oferta Handlowa B2B</p>
            <p className="text-sm text-stone-400 mt-2 italic font-serif">Wygenerowano dnia: {new Date().toLocaleDateString('pl-PL')}</p>
          </div>
          <div className="text-right">
             <h2 className="text-2xl font-black text-amber-900 uppercase">Oferta Ofertowa</h2>
             <p className="text-sm text-stone-400">Numer ref: {Math.random().toString(36).substr(2, 9).toUpperCase()}</p>
          </div>
        </div>

        <table className="w-full text-left">
          <thead>
            <tr className="bg-amber-900 text-white uppercase text-[10px] font-black tracking-[0.2em]">
              <th className="p-5 rounded-l-2xl">Lp.</th>
              <th className="p-5">Produkt / Specyfikacja</th>
              <th className="p-5 text-center">Ilość</th>
              <th className="p-5 text-right">Cena Jedn.</th>
              <th className="p-5 text-right rounded-r-2xl">Wartość Brutto</th>
            </tr>
          </thead>
          <tbody className="text-sm">
            {cart.map((item, index) => (
              <tr key={item.id} className="border-b border-stone-100">
                <td className="p-6 text-stone-300 font-black italic">{index + 1}.</td>
                <td className="p-6">
                  <p className="font-black text-stone-900 text-lg">{item.name}</p>
                  <p className="text-[10px] text-orange-600 font-bold uppercase tracking-widest">{item.category}</p>
                </td>
                <td className="p-6 text-center text-xl font-bold">{item.qty}</td>
                <td className="p-6 text-right font-mono text-stone-400">{item.price.toFixed(2)} PLN</td>
                <td className="p-6 text-right font-black text-2xl text-amber-950 font-mono">{(item.qty * item.price).toFixed(2)} PLN</td>
              </tr>
            ))}
          </tbody>
          <tfoot>
            <tr className="bg-stone-50 font-black">
              <td colSpan="4" className="p-10 text-right text-xl uppercase tracking-widest text-stone-400 italic">Razem do zapłaty:</td>
              <td className="p-10 text-right text-5xl text-amber-900 italic font-mono">{totalValue.toFixed(2)} <small className="text-lg not-italic font-bold">PLN</small></td>
            </tr>
          </tfoot>
        </table>

        <div className="mt-20 grid grid-cols-2 gap-16">
          <div className="p-8 border-l-8 border-orange-500 bg-stone-50 rounded-r-3xl">
            <h4 className="font-black text-xs uppercase mb-4 tracking-widest text-amber-950">Warunki współpracy Fotoastra:</h4>
            <ul className="text-[11px] text-stone-500 space-y-2 font-medium leading-relaxed">
              <li>• Ceny w ofercie są cenami brutto (zawierają podatek VAT).</li>
              <li>• Wszystkie kawy pochodzą z najświeższych partii importowych.</li>
              <li>• Dostawa realizowana w ciągu 48h od potwierdzenia zamówienia.</li>
              <li>• Darmowa przesyłka kurierska dla zamówień powyżej 1500 PLN.</li>
            </ul>
          </div>
          <div className="flex flex-col items-center justify-end">
             <div className="border-b-2 border-dotted border-stone-300 w-full mb-2"></div>
             <p className="text-[10px] uppercase text-stone-400 font-black tracking-widest">Podpis i pieczęć wystawcy oferty</p>
          </div>
        </div>
      </div>

      {/* Footer */}
      <footer className="max-w-7xl mx-auto p-12 mt-12 border-t border-stone-200 text-center text-stone-400 no-print">
        <p className="font-black uppercase tracking-[0.3em] text-amber-900/40 mb-2">Fotoastra Import</p>
        <p className="text-xs">System generowania ofert B2B na podstawie asortymentu kawowego i słodyczy.</p>
      </footer>
    </div>
  );
};

export default App;
