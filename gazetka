            <h3 className="text-lg font-black mb-6 flex items-center gap-2 border-b border-amber-900 pb-3 uppercase italic">
              <ShoppingCart size={22} className="text-orange-500" /> Twoja Gazetka
            </h3>
            
            {cart.length === 0 ? (
              <div className="py-12 text-center text-amber-500 opacity-60 italic">
                <p className="text-sm tracking-wide">Wybierz produkty z listy po lewej,<br/>aby stworzyć wycenę dla klienta.</p>
              </div>
            ) : (
              <>
                <div className="max-h-[400px] overflow-y-auto mb-6 pr-2 scrollbar-thin scrollbar-thumb-amber-800">
                  {cart.map(item => (
                    <div key={item.id} className="flex justify-between items-center py-4 border-b border-amber-900 last:border-0 group">
                      <div className="flex-grow min-w-0 pr-4">
                        <h4 className="text-sm font-bold text-white line-clamp-1 group-hover:text-orange-400 transition-colors">{item.name}</h4>
