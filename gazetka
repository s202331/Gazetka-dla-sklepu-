        <div className="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
          <div className="flex items-center gap-3">
            <div className="bg-white p-2 rounded-full text-amber-900 shadow-inner">
              <Coffee size={32} />
            </div>
            <div>
              <h1 className="text-2xl font-black tracking-tighter uppercase italic">Fotoastra Coffee</h1>
              <p className="text-amber-200 text-xs font-bold tracking-widest uppercase opacity-80">Słodko gorzko</p>
            </div>
          </div>
          
          <div className="flex items-center gap-4 w-full md:w-auto">
            <div className="relative flex-grow md:w-72">
              <Search className="absolute left-3 top-2.5 text-amber-400" size={18} />
              <input 
                type="text" 
                placeholder="Szukaj produktu (np. illy, Lindt)..." 
                className="pl-10 pr-4 py-2 rounded-xl bg-amber-800 border-none text-white placeholder-amber-400 focus:ring-2 focus:ring-orange-400 w-full outline-none transition-all"
                value={searchTerm}
                onChange={(e) => setSearchTerm(e.target.value)}
              />
            </div>
            <button 
              onClick={() => setShowOffer(!showOffer)}
              className="relative p-2.5 bg-orange-600 hover:bg-orange-500 rounded-xl transition-all shadow-lg active:scale-95"
            >
              <ShoppingCart size={24} />
              {cart.length > 0 && (
                <span className="absolute -top-1 -right-1 bg-white text-orange-600 text-[10px] font-black px-2 py-0.5 rounded-full shadow-md">
                  {cart.length}
                </span>
              )}
            </button>
          </div>
        </div>
      </header>

      {/* Category Tabs */}
      <nav className="bg-white border-b border-stone-200 sticky top-[88px] z-10 no-print">
        <div className="max-w-7xl mx-auto px-4 overflow-x-auto flex gap-2 py-3 scrollbar-hide">
          {CATEGORIES.map(cat => (
            <button
              key={cat}
              onClick={() => setSelectedCategory(cat)}
              className={`px-4 py-2 rounded-full text-xs font-black uppercase tracking-wider transition-all whitespace-nowrap ${
                selectedCategory === cat 
                ? 'bg-amber-900 text-white shadow-md' 
                : 'text-stone-400 hover:bg-stone-100'
              }`}
            >
              {cat}
            </button>
          ))}
        </div>
      </nav>

      <main className="max-w-7xl mx-auto p-4 md:p-8 flex flex-col lg:flex-row gap-8">
        
        {/* Product Grid */}
        <div className={`flex-grow ${showOffer ? 'lg:w-2/3' : 'w-full'}`}>
          <div className="mb-8 border-l-4 border-orange-500 pl-4">
            <h2 className="text-2xl font-black text-stone-800 uppercase tracking-tight">
              {selectedCategory} <span className="text-stone-400 text-lg ml-2">({filteredProducts.length})</span>
            </h2>
          </div>
          
          <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
            {filteredProducts.map(product => (
              <div key={product.id} className="bg-white rounded-2xl shadow-sm border border-stone-200 overflow-hidden hover:shadow-xl transition-all group border-b-4 border-b-stone-100 flex flex-col">
               <div className="h-40 bg-white flex items-center justify-center overflow-hidden">
  <img
    src={product.img}
    alt={product.name}
    className="h-full w-full object-contain p-4"
  />
</div>
                <div className="p-5 flex flex-grow flex-col">
                  <span className="text-[10px] font-black text-orange-600 bg-orange-50 px-2.5 py-1 rounded-full mb-3 inline-block uppercase tracking-widest">
                    {product.category}
                  </span>
                  <h3 className="font-bold text-lg mb-1 text-stone-800 leading-tight">{product.name}</h3>
                  <p className="text-stone-400 text-xs mb-6 h-8 line-clamp-2 leading-relaxed">{product.desc}</p>
                  
                  <div className="mt-auto pt-4 border-t border-stone-50 flex items-center justify-between">
