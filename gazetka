const CATEGORIES = ["Wszystkie", "Kawa Ziarnista", "Kawa Mielona", "Rozpuszczalna / Instant", "Słodycze i Kremy", "Spiżarnia i Inne"];

const App = () => {
  const [cart, setCart] = useState([]);
  const [searchTerm, setSearchTerm] = useState("");
  const [selectedCategory, setSelectedCategory] = useState("Wszystkie");
  const [showOffer, setShowOffer] = useState(false);

  const addToCart = (product) => {
    const existing = cart.find(item => item.id === product.id);
    if (existing) {
      setCart(cart.map(item => item.id === product.id ? { ...item, qty: item.qty + 1 } : item));
    } else {
      setCart([...cart, { ...product, qty: 1 }]);
    }
  };

  const removeFromCart = (id) => {
    setCart(cart.filter(item => item.id !== id));
  };

  const filteredProducts = ALL_PRODUCTS.filter(p => {
    const matchesSearch = p.name.toLowerCase().includes(searchTerm.toLowerCase());
    const matchesCategory = selectedCategory === "Wszystkie" || p.category === selectedCategory;
    return matchesSearch && matchesCategory;
  });

  const totalValue = cart.reduce((acc, curr) => acc + (curr.price * curr.qty), 0);

  return (
