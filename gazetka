                      <span className="text-[10px] font-bold text-stone-300 uppercase">Cena Brutto</span>
                      <span className="text-2xl font-black text-amber-950">{product.price.toFixed(2)} <small className="text-[10px] font-normal">PLN</small></span>
                    </div>
                    <button 
                      onClick={() => addToCart(product)}
                      className="bg-amber-900 hover:bg-orange-600 text-white p-3 rounded-xl transition-all shadow-md active:scale-90"
                    >
                      <Check size={20} />
                    </button>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        {/* Sidebar: Selection Only */}
        <aside className={`${showOffer ? 'block' : 'hidden'} lg:block lg:w-96 space-y-6`}>
